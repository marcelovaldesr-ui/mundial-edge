# ─── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # solo server-side / sync

# ─── Modo de datos ─────────────────────────────────────────
# mock  -> dataset local (sin llamadas externas; ideal para MVP/demo)
# live  -> proveedores reales (requiere API_FOOTBALL_KEY + Supabase)
DATA_MODE=mock

# ─── API-Football (PROVEEDOR PRINCIPAL — plan free, sin tarjeta) ──
# Regístrate en https://dashboard.api-football.com (100 req/día gratis)
# Una sola key cubre fixtures, resultados, estadísticas y cuotas.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE=1        # 1 = FIFA World Cup
API_FOOTBALL_SEASON=2026

# ─── Cuotas: proveedor a usar ──────────────────────────────
# api-football (por defecto, usa la key de arriba) | the-odds-api (respaldo)
ODDS_PROVIDER=api-football

# ─── The Odds API (RESPALDO opcional de cuotas) ────────────
# Solo si ODDS_PROVIDER=the-odds-api. https://the-odds-api.com (500 créditos/mes)
ODDS_API_KEY=
ODDS_API_BASE=https://api.the-odds-api.com/v4
ODDS_SPORT_KEY=soccer_fifa_world_cup

# ─── Seguridad de jobs ─────────────────────────────────────
# Token que Vercel Cron y el panel admin deben enviar para disparar sync
CRON_SECRET=genera-un-token-aleatorio-largo
