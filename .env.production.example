# Modelo estadístico recomendado para lanzamiento
STAT_MODEL_VARIANT=calibrated-matrix
STAT_MODEL_CALIBRATION=none
CALIBRATION_TEMPERATURE=0.65

# Simulación y filtros de producto
SIMULATION_ITERATIONS=10000
MIN_EDGE_DEFAULT=0.02
MIN_CONFIDENCE_FILTER=low
MAX_PARLAYS_PER_REQUEST=50

# Fuente de datos: mock para demo; live requiere credenciales del proveedor
DATA_MODE=live
API_FOOTBALL_KEY=
API_FOOTBALL_BASE=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2026
ODDS_PROVIDER=api-football

# Supabase se usa tanto en servidor como en el cliente; sólo estas dos claves
# públicas llevan NEXT_PUBLIC_. Nunca prefijar service-role keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Protección del endpoint cron (sólo servidor)
CRON_SECRET=
